rofi.modi:     window,run,ssh,drun
rofi.font:     Hack Nerd Font 12
rofi.bw:       2
rofi.location: 0
rofi.padding:  5
rofi.lines:    10
rofi.show-icons: true
rofi.terminal: st
!rofi.drun-show-actions: true

rofi.kb-select-1:    Control+1
rofi.kb-select-2:    Control+2
rofi.kb-select-3:    Control+3
rofi.kb-select-4:    Control+4
rofi.kb-select-5:    Control+5
rofi.kb-select-6:    Control+6
rofi.kb-select-7:    Control+7
rofi.kb-select-8:    Control+8
rofi.kb-select-9:    Control+9
rofi.kb-select-10:   Control+0

! "Color scheme for normal row" Set from: Default
! rofi.color-normal:                   
! "Color scheme for urgent row" Set from: Default
! rofi.color-urgent:                   
! "Color scheme for active row" Set from: Default
! rofi.color-active:                   
! "Color scheme window" Set from: Default
! rofi.color-window:                   

rofi.kb-clear-line:                  Control+l
rofi.kb-remove-word-back:            Control+w,Control+BackSpace
rofi.kb-remove-word-forward:         Control+W
rofi.kb-row-up:                      Up,Alt+k
rofi.kb-row-down:                    Down,Alt+j
