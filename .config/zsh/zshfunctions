# cd's to the top of the current git repo
cdgr() {
	_isgit=$(git rev-parse --is-inside-work-tree 2>/dev/null)

	if [ "$_isgit" = true ]; then
		cd $(git rev-parse --show-toplevel)
	else
		2>&1 echo "cdgr: bad working directory: not inside a git repository"
		return 1
	fi
}

# copy arguments to clipboard. useful to copy a path since the arguments
# can be completed using zsh's completion system
yargs() {
	local _opts _absolute
	while [[  "$1" ==  -* ]]; do
		case "$1" in
			-c|--clipboard) # copy to system clipboard instead of primary
				_opts="-selection clipboard"
				shift ;;
			-a|--absolute) # if arg is a relative path, copy the absolute path
				_absolute="true"
				shift ;;
		esac
	done


	args=$(echo -n $@ | tr -d '\n')

	if [ "$_absolute" = true -a $# = 1 ]; then
		args="$PWD/$args"
	fi

	echo -n $args | xclip ${=_opts}
}
