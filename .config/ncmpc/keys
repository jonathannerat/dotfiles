## Key bindings for ncmpc (generated by ncmpc)

## Key configuration screen
key screen-keyedit = Ctrl-K

## Quit
key quit = 'Q'

## Move cursor up
key up = 'k'

## Move cursor down
key down = 'j'

## Move cursor to the top of the list
key home = 'g',  262

## Move cursor to the bottom of the list
key end = 'G',  360

## Page up
key pgup = Ctrl-B,  339

## Page down
key pgdn = Ctrl-F,  338

## Scroll down one line
key scroll-down-line = Ctrl-E

## Scroll up one line
key scroll-up-line = Ctrl-Y

## Scroll up half a screen
key scroll-down-half = Ctrl-D

## Scroll down half a screen
key scroll-up-half = Ctrl-U

## Help screen
key screen-help = F1,  '1'

## Increase volume
key volume-up = 43

## Decrease volume
key volume-down = 45

## Start a music database update
key db-update = 0

## Go to parent directory
key go-parent-directory = 34,  'q'

## Locate song in browser
key locate = 0

## Move item up
key move-up = 'K'

## Move item down
key move-down = 'J'

## Toggle auto center mode
key autocenter-mode = 0

## Swap to most recent screen
key screen-swap = 'X'

## Interrupt action
key lyrics-interrupt = 0

## Update Lyrics
key lyrics-update = 0

