# vi: syntax=tmux
set -g default-terminal "tmux-256color"
set -g prefix C-a
set -g status-keys vi
set -g mode-style bg=black
set -g automatic-rename on

set -sg escape-time 10

setenv -g TERM "tmux-256color"

setenv -g TERM "tmux-256color"

unbind C-b
unbind l
unbind %
unbind \"

bind C-a send-prefix


bind b command-prompt -p "(swap-pane-with)" "swap-pane -d -t %%"
bind B command-prompt -p "(swap-window-with)" "swap-window -d -t %%"
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R
bind r source-file ~/.config/tmux/config

bind | split-window -h
bind - split-window -v

# status bar theme

set -g status on
set -g status-position top
set -g status-justify centre
set -g status-left-length 200
set -g status-right-length 200
set -g status-style fg=white,bg=black

set -g message-style fg=yellow,bg=black
set -g message-command-style fg=yellow,bg=black

set -g pane-border-style fg=white
set -g pane-active-border-style fg=yellow

set -g window-status-style fg=magenta,bg=black
set -g window-status-activity-style bg=magenta,fg=black
set -g window-status-bell-style bg=magenta,fg=black
set -g window-status-separator ' | '

set -g status-right '#[fg=green,bold]#(whoami)#[fg=white]@#[fg=blue]#H '
set -g status-left '#[fg=red,bold][#S] '

set -g window-status-format ' #I:[ #W ] #F '
set -g window-status-current-format ' #[bold]#I:[ #W ] #F '

