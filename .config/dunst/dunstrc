# vi: ft=cfg
[global]
	follow = keyboard
	indicate_hidden = yes

	# {w}x{h}±{x}±{y}
	geometry = "350x5-10+42"
	shrink = no

	separator_height = 1
	padding = 10
	horizontal_padding = 10
	frame_width = 2
	separator_color = frame

	sort = yes
	idle_threshold = 120

	font = Iosevka Nerd Font 10
	line_height = 0

	markup = full
	format = "<b>%s</b>\n%b"
	show_age_threshold = 60
	word_wrap = yes

	ignore_newline = no
	stack_duplicates = true
	hide_duplicate_count = false
	show_indicators = yes

	### Icons ###
	icon_position = left
	max_icon_size = 80
	icon_path = /usr/share/icons/Tela-manjaro-dark/22/actions:/usr/share/icons/Tela-manjaro-dark/22/devices:/usr/share/icons/Tela-manjaro-dark/22/emblems:/usr/share/icons/Tela-manjaro-dark/22/mimetypes:/usr/share/icons/Tela-manjaro-dark/22/panel:/usr/share/icons/Tela-manjaro-dark/22/places:/usr/share/icons/Tela-manjaro-dark/symbolic/apps:/usr/share/icons/Tela-manjaro-dark/symbolic/categories:/usr/share/icons/Tela-manjaro-dark/symbolic/emotes:/usr/share/icons/Tela-manjaro-dark/symbolic/status

	### History ###
	sticky_history = yes
	history_length = 20

	### Misc/Advanced ###
	dmenu = /usr/local/bin/dmenu -p dunst: -l 5 -c -B
	browser = /usr/bin/xdg-open

	startup_notification = true
	verbosity = mesg

	### Mouse
	mouse_left_click = close_current
	mouse_middle_click = do_action
	mouse_right_click = close_all

[shortcuts]
	close = mod1+grave
	close_all = mod1+shift+grave
	history = mod1+shift+comma
	context = mod1+shift+period

[urgency_low]
	timeout = 5
	background = "#1d2021"
	foreground = "#F2F2F2"
	frame_color = "#F2F2F2"

[urgency_normal]
	timeout = 10
	background = "#7daea3"
	foreground = "#1d2021"
	frame_color = "#20433b"

[urgency_critical]
	timeout = 0
	background = "#ea6962"
	foreground = "#1d2021"
	frame_color = "#7e241f"
