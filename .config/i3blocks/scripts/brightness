#!/bin/sh

_level=$(xbacklight -get)

# change icon based on brightness level
if [ $_level -gt 80 ]; then _icon="ď—ź "
elif [ $_level -gt 60 ]; then _icon="ď—ž "
elif [ $_level -gt 40 ]; then _icon="ď—ť "
elif [ $_level -gt 20 ]; then _icon="ď—š "
else _icon="ď—™ "
fi

# for better alignment
[ $_level -eq 100 ] && echo "$_icon$_level%" || echo "$_icon $_level%"
