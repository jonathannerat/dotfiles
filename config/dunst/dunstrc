# vi: ft=cfg
[global]
	follow = keyboard
	indicate_hidden = yes

	width = (0, 300)
	height = 100
	offset = 0x24
	shrink = no
	frame_width = 1
	corner_radius = 5
	separator_height = 1
	notification_limit = 5

	padding = 10
	horizontal_padding = 15
	separator_color = frame

	sort = yes
	idle_threshold = 120

	font = SFMono Nerd Font 10
	line_height = 0

	markup = full
	format = "<b>%s</b>\n%b"
	show_age_threshold = 60
	word_wrap = yes

	ignore_newline = no
	stack_duplicates = true
	hide_duplicate_count = false
	show_indicators = yes

	### Icons ###
	icon_position = left
	max_icon_size = 50
	icon_path = /usr/share/icons/Papirus-Dark/symbolic/emblems:/usr/share/icons/Papirus-Dark/symbolic/categories:/usr/share/icons/Papirus-Dark/symbolic/status:/usr/share/icons/Papirus-Dark/symbolic/actions:/usr/share/icons/Papirus-Dark/symbolic/apps:/usr/share/icons/Papirus-Dark/symbolic/devices:/usr/share/icons/Papirus-Dark/symbolic/mimetypes:/usr/share/icons/Papirus-Dark/symbolic/places:/usr/share/icons/Papirus-Dark/symbolic/emotes:/usr/share/icons/Papirus-Dark/22x22/actions/:/usr/share/icons/Papirus/22x22/emblems:/usr/share/icons/Papirus/22x22/status:/usr/share/icons/Papirus/22x22/actions:/usr/share/icons/Papirus/22x22/panel:/usr/share/icons/Papirus/22x22/apps:/usr/share/icons/Papirus/22x22/devices:/usr/share/icons/Papirus/22x22/mimetypes:/usr/share/icons/Papirus/22x22/animations:/usr/share/icons/Papirus/22x22/places:/usr/share/icons/Papirus/22x22/emotes

	### History ###
	sticky_history = yes
	history_length = 20

	### Misc/Advanced ###
	dmenu = /usr/local/bin/dmenu -p dunst: -l 5 -c -B
	browser = /usr/bin/xdg-open

	### Mouse
	mouse_left_click = close_current
	mouse_middle_click = do_action
	mouse_right_click = close_all

[urgency_low]
	timeout = 5
	background = "#1d2021"
	foreground = "#cfcfcf"
	frame_color = "#a2a2a2"

[urgency_normal]
	timeout = 10
	background = "#1d2021"
	foreground = "#f2f2f2"
	frame_color = "#7daea3"

[urgency_critical]
	timeout = 0
	background = "#1d2021"
	foreground = "#f2f2f2"
	frame_color = "#ea6962"
