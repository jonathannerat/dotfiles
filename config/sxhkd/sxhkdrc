# vi: fdm=marker
# === MEDIA === {{{
XF86Audio{Lower,Raise}Volume
	pamixer --max-volume 50 -{d,i} 5

shift + XF86Audio{Lower,Raise}Volume
	pamixer -{d,i} 5

XF86AudioMute
	pamixer -t

XF86Audio{Play,Prev,Next}
	mpc {toggle,prev,next}

ctrl + shift + XF86AudioPrev
	mpc seek 0

ctrl + XF86Audio{Prev,Next}
	mpc seek {-,+}10

shift + XF86Audio{Prev,Next}
	mpc seek {-,+}1:00
#}}}

# === APPS === {{{
super + shift + p
	rofi -show drun

super + shift + Return
	alacritty

super + ctrl + Return
	alacritty --class=floating-alacritty

super + ctrl + e
	alacritty --class=floating-alacritty -e n

super + alt + {u,i,o,p}
	{browser,zattab,xournalpp,pavucontrol}
#}}}

# === OTHER === {{{
# Helper dmenus
super + shift + {ctrl + u, u, o}
	dmenu-{unicode -C,unicode,kaomojis} -bw 2 -l 20 -fn "Noto Sans:style=Regular:pixelsize=16:autohint=true:antialias=true"

super + shift + i
	dmenu-nficons -bw 2 -l 20 -fn "TerminessTTF Nerd Font:style=Regular:pixelsize=16:autohint=true:antialias=true"

super + shift + b
	passmenu -bw 2 -l 20

# Screenshots
{,super,shift,ctrl,shift+ctrl} + @Print
	imgkprnt -{c,cm,cw,caO,ca}
#}}}
